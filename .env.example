# Medical RAG Assistant - Environment Configuration

# =============================================================================
# EXTERNAL API KEYS
# =============================================================================

# Alibaba Cloud (if using)
ALIBABA_API_KEY=your_api_key_here
ALIBABA_API_SECRET=your_api_secret_here
ALIBABA_API_REGION=your_api_region_here
ALIBABA_API_ENDPOINT=your_api_endpoint_here

# OpenAI API Key (required for LLM and Judge)
OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# QDRANT VECTOR DATABASE
# =============================================================================

# Qdrant server URL
# Local: http://localhost:6333
# Cloud: https://your-cluster.qdrant.io
QDRANT_URL=http://localhost:6333

# Qdrant API key (optional for local, required for cloud)
QDRANT_API_KEY=

# Collection name for medical documents
QDRANT_COLLECTION_NAME=medical_documents

# =============================================================================
# EMBEDDING MODELS
# =============================================================================

# Dense embedding model (semantic search)
# Options: BAAI/bge-large-en-v1.5, BAAI/bge-base-en-v1.5, BAAI/bge-small-en-v1.5
DENSE_MODEL_NAME=BAAI/bge-large-en-v1.5

# Sparse embedding model (keyword search)
SPARSE_MODEL_NAME=prithivida/Splade_PP_en_v1

# Re-ranker model (cross-encoder for re-ranking)
RERANKER_MODEL_NAME=BAAI/bge-reranker-base

# =============================================================================
# RETRIEVAL CONFIGURATION
# =============================================================================

# Number of documents to retrieve initially
RETRIEVAL_TOP_K=10

# Number of documents after re-ranking
RERANKER_TOP_K=3

# Weights for hybrid search (must sum to 1.0)
DENSE_WEIGHT=0.5
SPARSE_WEIGHT=0.5

# =============================================================================
# LLM CONFIGURATION
# =============================================================================

# Main LLM for answer generation
LLM_MODEL_NAME=gpt-4

# Temperature for answer generation (0.0-1.0)
LLM_TEMPERATURE=0.7

# Judge LLM for relevance grading
JUDGE_MODEL_NAME=gpt-3.5-turbo

# Temperature for judging (0.0 = deterministic)
JUDGE_TEMPERATURE=0.0

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Enable debug mode
DEBUG=false
